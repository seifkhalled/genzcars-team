# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://xxxx.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=cars_ads

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# AI
GEMINI_API_KEY=your-gemini-api-key
TAVILY_API_KEY=your-tavily-api-key

# Storage
SUPABASE_STORAGE_BUCKET=car-images

# Redis (optional, for production session memory)
REDIS_URL=

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

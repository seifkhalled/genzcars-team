# ── Supabase Cloud ────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.xxxx.supabase.co:5432/postgres
SUPABASE_STORAGE_BUCKET=car-images

# ── Qdrant Cloud ──────────────────────────────────────────────────
QDRANT_URL=https://xxxx.qdrant.io
QDRANT_API_KEY=...
QDRANT_COLLECTION=cars_ads

# ── Groq ──────────────────────────────────────────────────────────
GROQ_API_KEY=...
GROQ_MODEL=openai/gpt-oss-120b

# ── Tavily ────────────────────────────────────────────────────────
TAVILY_API_KEY=...

# ── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change_me_at_least_32_chars_long_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ───────────────────────────────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ── Service ports (used inside containers) ────────────────────────
CHATBOT_PORT=8001
COMPARISON_PORT=8002

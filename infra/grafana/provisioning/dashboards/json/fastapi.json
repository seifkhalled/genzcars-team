{
  "title": "FastAPI Service Overview",
  "uid": "fastapi-overview",
  "version": 2,
  "panels": [
    {
      "title": "Requests per Second",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Request Duration (p50, p95, p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "HTTP Error Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m]) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Calls per Second",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(llm_calls_total[5m])) by (service, task_type)",
          "legendFormat": "{{service}} - {{task_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Token Usage Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(llm_tokens_total[5m])) by (service, type)",
          "legendFormat": "{{service}} - {{type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Latency (p50, p95, p99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Cost per Hour",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(llm_cost_total_usd[5m])) by (service, provider)",
          "legendFormat": "{{service}} - {{provider}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Comparison & Research Requests",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(comparison_requests_total[5m])) by (service)",
          "legendFormat": "comparisons - {{service}}"
        },
        {
          "expr": "sum(rate(research_calls_total[5m])) by (service)",
          "legendFormat": "research - {{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "LLM Fallback Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(llm_fallback_total[5m])) by (service, task_type, from_provider, to_provider)",
          "legendFormat": "{{service}} - {{task_type}} ({{from_provider}} -> {{to_provider}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Comparison Errors",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "expr": "sum(rate(comparison_errors_total[5m])) by (service, error_type)",
          "legendFormat": "{{service}} - {{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "showPoints": "never" }
        }
      }
    },
    {
      "title": "Search Quality Pass Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 40 },
      "targets": [
        {
          "expr": "sum(search_quality_total{passed=\"true\"}) / sum(search_quality_total) * 100",
          "legendFormat": "pass rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    }
  ]
}
